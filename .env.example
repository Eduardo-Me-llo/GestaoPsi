# Supabase project used by the application.
# Copy this file to .env and fill it with the values from your Supabase project:
# Project Settings > API.
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key

# Required only by server-side rendering. For local Vite development,
# the VITE_ variables above are sufficient.
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_PUBLISHABLE_KEY=sb_publishable_your_public_key
# ---------------------------------------------------------------
# Painel administrativo (opcional)
# ---------------------------------------------------------------
# A chave service_role é necessária APENAS no servidor para as operações
# administrativas privilegiadas: criar psicólogo/admin, excluir usuário e
# definir senha diretamente. Encontre em Project Settings > API > service_role.
#
# ATENÇÃO: NUNCA exponha esta chave no navegador nem use o prefixo VITE_.
# Ela ignora a RLS e concede acesso total ao banco.
#
# Sem ela, o painel continua funcionando: bloquear/ativar/promover/redefinir
# senha por e-mail seguem operando via RLS; apenas criar/excluir contas de Auth
# e definir senha direta ficam indisponíveis.
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
